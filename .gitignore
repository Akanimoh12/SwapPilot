ai-engine/.pytest_cache/
ai-engine/.mypy_cache/
ai-engine/.ruff_cache/
ai-engine/data/raw/
ai-engine/data/models/*.pt
*.pyc
*.pyo

# ------- Next.js / Frontend -------
frontend/node_modules/
frontend/.next/
frontend/out/

# ------- Environment -------
.env
.env.local
.env.*.local

# ------- OS -------
.DS_Store
Thumbs.db

# ------- IDE -------
.vscode/
.idea/
*.swp
*.swo
