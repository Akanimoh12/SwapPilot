      { "name": "maxQueueTime", "type": "uint256" },
      { "name": "maxSlippage", "type": "uint256" },
      { "name": "isActive", "type": "bool" }
    ],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "getExecutionScore",
    "inputs": [{ "name": "poolId", "type": "bytes32" }],
    "outputs": [
