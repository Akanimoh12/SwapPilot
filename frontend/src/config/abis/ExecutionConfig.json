      { "name": "updatedAt", "type": "uint256" }
    ],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "isPoolActive",
    "inputs": [{ "name": "poolId", "type": "bytes32" }],
    "outputs": [{ "name": "", "type": "bool" }],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "shouldQueue",
    "inputs": [
      { "name": "poolId", "type": "bytes32" },
      { "name": "swapAmount", "type": "uint256" }
    ],
    "outputs": [{ "name": "", "type": "bool" }],
    "stateMutability": "view"
  },
  {
    "type": "function",
    "name": "shouldExecute",
    "inputs": [{ "name": "poolId", "type": "bytes32" }],
    "outputs": [{ "name": "", "type": "bool" }],
    "stateMutability": "view"
  },
