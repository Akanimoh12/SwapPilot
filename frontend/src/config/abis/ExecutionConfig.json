  },
  {
    "type": "event",
    "name": "ExecutionScoreUpdated",
    "inputs": [
      { "name": "poolId", "type": "bytes32", "indexed": true },
      { "name": "score", "type": "uint256", "indexed": false },
      { "name": "timestamp", "type": "uint256", "indexed": false }
