# Network: "testnet" (default) or "mainnet"
NEXT_PUBLIC_CHAIN=testnet

# RPC (defaults to https://sepolia.unichain.org for testnet)
NEXT_PUBLIC_UNICHAIN_RPC_URL=https://sepolia.unichain.org

# Contract addresses (deployed on Unichain Sepolia)
NEXT_PUBLIC_SWAPPILOT_HOOK_ADDRESS=0x4b38424B0F9EB7bA027b9a413B15B6Cc09d020c8
NEXT_PUBLIC_EXECUTION_CONFIG_ADDRESS=0xcCDB2468De9C89fA6e283B96A0A6714201610F8E
NEXT_PUBLIC_SWAP_ROUTER_ADDRESS=0x552431953dd3F087557196A383c436ddAab665ab

# Token addresses (MockERC20s on Unichain Sepolia)
NEXT_PUBLIC_TOKEN_USDC=0x45944B08fea203a7469C82A690F68fabF85B8283
NEXT_PUBLIC_TOKEN_WETH=0x4200000000000000000000000000000000000006
NEXT_PUBLIC_TOKEN_DAI=0xc993F01C962fd61a588BB00EfB5cc373764c4ADd

# WalletConnect project ID — get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# AI Engine URL (local FastAPI server)
NEXT_PUBLIC_AI_ENGINE_URL=http://localhost:8000
