# Network: "testnet" (default) or "mainnet"
NEXT_PUBLIC_CHAIN=testnet

# RPC (defaults to https://sepolia.unichain.org for testnet)
NEXT_PUBLIC_UNICHAIN_RPC_URL=https://sepolia.unichain.org

# Contract addresses (deployed on Unichain Sepolia)
NEXT_PUBLIC_POOL_MANAGER_ADDRESS=0x7c13D90950F542B297179e09f3A36EaA917A40C1
NEXT_PUBLIC_SWAPPILOT_HOOK_ADDRESS=0xCB611482dC1112f768B965d655d83b1DbcF420c8
NEXT_PUBLIC_EXECUTION_CONFIG_ADDRESS=0xe8cf0aCE4A7f5b940c3Cab327117045C03b79Ac3
NEXT_PUBLIC_SWAP_ROUTER_ADDRESS=0xd48ee69b1206c3fdD17E5668A2725E10c2B0f11D
NEXT_PUBLIC_LIQUIDITY_ROUTER_ADDRESS=0xbA7C987537E1F7872bc4E7f856921CFe10389c20

# Token addresses (MockERC20s on Unichain Sepolia)
NEXT_PUBLIC_TOKEN_USDC=0x20E8307cFe2C5CF7E434b5Cb2C92494fa4BAF01C
NEXT_PUBLIC_TOKEN_WETH=0x4200000000000000000000000000000000000006
NEXT_PUBLIC_TOKEN_DAI=0x7d1dea64e891dccb20f85bC379227238c8C1308b

# Pool ID (mUSDC/mDAI with hook)
NEXT_PUBLIC_POOL_ID=0x95c7854a55b159e9d9cccafea079519fcaca1094e74865f9801237a89904a8ad

# WalletConnect project ID — get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# AI Engine URL (local FastAPI server)
NEXT_PUBLIC_AI_ENGINE_URL=http://localhost:8000
