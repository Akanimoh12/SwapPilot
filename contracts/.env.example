# SwapPilot Environment Variables

# Unichain Mainnet RPC URL (Chain ID: 130)
UNICHAIN_RPC_URL=https://mainnet.unichain.org

# Unichain Sepolia Testnet RPC URL (Chain ID: 1301)
UNICHAIN_TESTNET_RPC_URL=https://sepolia.unichain.org

# Reactive Network Mainnet RPC URL (Chain ID: 1597)
REACTIVE_RPC_URL=https://mainnet-rpc.rnk.dev/

# Deployer Private Key (no 0x prefix)
PRIVATE_KEY=

# Etherscan / Block Explorer API Key (for contract verification)
ETHERSCAN_API_KEY=

# Uniswap v4 PoolManager Address on Unichain Sepolia
# See: https://docs.uniswap.org/contracts/v4/deployments
POOL_MANAGER_ADDRESS=

# PoolSwapTest Router Address (deployed by Uniswap on testnet)
SWAP_ROUTER_ADDRESS=

# Reactive Network Callback Proxy Address on Unichain
CALLBACK_PROXY_ADDRESS=0x9299472A6399Fd1027ebF067571Eb3e3D7837FC4
